{
  "expo": {
    "name": "Zikra",
    "slug": "zikra",
    "scheme": "zikra",
    "locales": {
      "tr": "./locales/tr.json",
      "en": "./locales/en.json",
      "ar": "./locales/ar.json",
      "id": "./locales/id.json"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yusuf.zikraapp",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Zikra requires precise location access to calculate astronomical prayer times and determine the Qibla angle relative to True North for your specific coordinates, in compliance with Diyanet standards.",
        "NSSpeechRecognitionUsageDescription": "Zikra uses on-device speech recognition to enable hands-free Dhikr counting, allowing accessible usage for users with limited mobility.",
        "NSMicrophoneUsageDescription": "Zikra accesses the microphone strictly for real-time speech recognition during Dhikr sessions. Audio is processed locally and never stored or transmitted.",
        "NSUserTrackingUsageDescription": "Zikra requests permission to deliver personalized advertising relevant to your interests. Your data is not linked to your identity across other apps and websites.",
        "NSCameraUsageDescription": "Zikra needs access to your camera to let you take a profile photo.",
        "NSPhotoLibraryUsageDescription": "Zikra needs access to your photo library to let you choose a profile photo.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        },
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yusuf.zikraapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Zikra to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#10B981",
          "sounds": [
            "./assets/sounds/adhan.mp3"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "./plugins/withTrackPlayer",
      "./plugins/withTrackPlayer",
      "./plugins/withWidget",
      [
        "expo-dynamic-app-icon",
        {
          "icons": {
            "light": {
              "image": "./assets/images/icon_light.png",
              "prerendered": true
            },
            "dark": {
              "image": "./assets/images/icon_dark.png",
              "prerendered": true
            },
            "blue_gold": {
              "image": "./assets/images/icon_blue_gold.png",
              "prerendered": true
            },
            "sage": {
              "image": "./assets/images/icon_sage.png",
              "prerendered": true
            },
            "silver": {
              "image": "./assets/images/icon_silver.png",
              "prerendered": true
            },
            "burgundy": {
              "image": "./assets/images/icon_burgundy.png",
              "prerendered": true
            },
            "navy_red": {
              "image": "./assets/images/icon_navy_red.png",
              "prerendered": true
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2636bcd5-49b8-4f8d-a35a-0f67d3a4fdad"
      }
    },
    "owner": "myusufuysal",
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-3940256099942544~3347511713",
      "ios_app_id": "ca-app-pub-3940256099942544~1458002511"
    }
  }
}